{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "./**/*.ts",
    "../src/lib/**/*.ts",
    "../src/types/**/*.ts"
  ],
  "exclude": ["../src/**/*.tsx", "../src/main.tsx", "../src/App.tsx"]
}
